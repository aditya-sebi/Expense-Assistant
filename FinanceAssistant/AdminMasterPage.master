<%@ Master Language="C#" AutoEventWireup="true" CodeFile="AdminMasterPage.master.cs" Inherits="AdminMasterPage" %>

<!DOCTYPE html>

<html>
<<head runat="server">
    <title>Admin Panel | AI Finance Assistant</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f4f7fb;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: #0b2c3d;
            position: fixed;
            top: 0;
            left: 0;
            padding: 20px;
            color: #fff;
        }

        .sidebar h4 {
            color: #00e5ff;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            color: #fff;
            text-decoration: none;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: 0.3s ease;
        }

        .sidebar a i {
            margin-right: 10px;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(0,229,255,0.25);
        }

        /* Main Content */
        .main-content {
            margin-left: 280px;
            padding: 25px;
        }

        /* Top Bar */
        .top-bar {
            background: #fff;
            border-radius: 18px;
            padding: 15px 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            margin-bottom: 25px;
        }

        /* Page Card */
        .page-card {
            background: #fff;
            border-radius: 22px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        }
    </style>
</head>

<body>
<form id="form1" runat="server">

    <!-- Sidebar -->
    <div class="sidebar">
        <h4>AI Finance Admin</h4>

        <a href="AdminDashboard.aspx" class="active">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="AdminManageUsers.aspx">
            <i class="bi bi-people"></i> Manage Users
        </a>

        <a href="AdminIncomeRecords.aspx">
            <i class="bi bi-wallet2"></i> Income Records
        </a>

        <a href="AdminExpenseRecords.aspx">
            <i class="bi bi-receipt"></i> Expense Records
        </a>

        <a href="AdminSendMessage.aspx">
            <i class="bi bi-chat-left-text"></i> Send Messages
        </a>
          <a href="AdminMessages.aspx">
      <i class="bi bi-chat-left-text"></i> View Messages
       </a>
        <a href="AdminUploadDataset.aspx">
            <i class="bi bi-graph-up"></i> Training
        </a>

        <a href="Homepage.aspx">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Top Bar -->
        <div class="top-bar d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Admin Panel</h5>
            <span class="text-muted">Welcome, Administrator</span>
        </div>

        <!-- Page Content -->
        <div class="page-card">
            <asp:ContentPlaceHolder ID="MainContent" runat="server"></asp:ContentPlaceHolder>
        </div>

    </div>

</form>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
